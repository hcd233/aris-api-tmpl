#!/bin/sh
# Pre-commit hook: run Go checks before committing.
set -eu

GO_BIN="${GO_BIN:-go}"
export GOTOOLCHAIN=auto
export PATH="$PATH:/usr/local/go/bin:$HOME/go/bin:$HOME/sdk/go/bin"

PASS="\033[32m[PASS]\033[0m"
FAIL="\033[31m[FAIL]\033[0m"
INFO="\033[34m[INFO]\033[0m"

fail() {
    printf "$FAIL %s\n" "$1"
    exit 1
}

printf "$INFO Running gofmt on tracked Go files...\n"
git ls-files '*.go' | while IFS= read -r file; do
    if [ -n "$file" ]; then
        gofmt -w "$file"
    fi
done

FORMATTED=$(git diff --name-only -- '*.go')
if [ -n "$FORMATTED" ]; then
    printf "$INFO gofmt reformatted files, staging changes:\n"
    printf '%s\n' "$FORMATTED" | sed 's/^/       /'
    printf '%s\n' "$FORMATTED" | xargs git add
fi
printf "$PASS gofmt\n"

printf "$INFO Running go mod tidy...\n"
$GO_BIN mod tidy
if ! git diff --quiet -- go.mod go.sum; then
    printf "$INFO go.mod or go.sum changed, staging changes:\n"
    git diff --name-only -- go.mod go.sum | sed 's/^/       /'
    git add go.mod go.sum
fi
printf "$PASS go mod tidy\n"

printf "$INFO Running make lint...\n"
if ! make lint; then
    fail "make lint failed. Please fix the issues above before committing."
fi
printf "$PASS make lint\n"

printf "$INFO Running make test...\n"
if ! make test; then
    fail "make test failed. All tests must pass before committing."
fi
printf "$PASS make test\n"

printf "\n$PASS All checks passed. Proceeding with commit.\n"
